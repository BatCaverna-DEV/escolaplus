# ============================
# SERVIDOR
# ============================
PORT=3002
NODE_ENV=development

# ============================
# BANCO DE DADOS (Sequelize)
# ============================
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=escolaplus

# ============================
# AUTENTICAÇÃO (JWT)
# ============================
JWT_SECRET=troque_por_uma_string_segura_e_aleatoria
JWT_EXPIRE=3h

# ============================
# CONFIGURAÇÕES DE LOG
# ============================
LOG_LEVEL=debug

# ============================
# E-MAIL (Nodemailer)
# ============================
EMAIL_HOST=smtp.example.com
EMAIL_USER=seu@email.com
EMAIL_PASS=sua_senha
EMAIL_PORT=465
EMAIL_SECURE=true
